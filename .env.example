# ===== ضروری =====
BOT_TOKEN=                     # توکن ربات از BotFather
PUBLIC_URL=                    # آدرس عمومی سرور، مثل https://yourapp.up.railway.app
WEBHOOK_SECRET=change-me       # یک رشته دلخواه و رندوم برای امنیت وبهوک
PORT=3000

# آیدی عددی ادمین‌ها (با کاما جدا کن) - همان‌هایی که دکمه‌های تایید/رد رو تو تلگرام می‌بینن
ADMIN_IDS=

# رمز ورود پنل ادمین تحت وب (admin/index.html)
ADMIN_PANEL_PASSWORD=change-me

# ===== اختیاری =====
REQUIRED_CHANNEL=              # یوزرنیم کانال بدون @ - اگه ست بشه، عضویت اجباری میشه
COMMUNITY_CHANNEL=
COMMUNITY_CHAT=

REFERRAL_PERCENT=5             # درصد پورسانت معرف از خرید زیرمجموعه
GIFT_MARKET_FEE_PERCENT=5      # کارمزد پلتفرم روی بازار گیفت (امانی)
SWAP_FEE_PERCENT=1             # کارمزد تبدیل بین تومان و ارز دیجیتال

# شماره کارت مقصد که تو مینی‌اپ برای شارژ کارت‌به‌کارت نشون داده میشه
ADMIN_CARD_NUMBER=
ADMIN_CARD_OWNER=
